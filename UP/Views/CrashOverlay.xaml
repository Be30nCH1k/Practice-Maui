<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UP.Views.CrashOverlay"
             IsVisible="False">

    <!-- полупрозрачный затемняющий фон -->
    <Grid x:Name="RootGrid" BackgroundColor="Black">

        <!-- краш 1 взлом -->
        <VerticalStackLayout x:Name="CrashBSOD"
                             IsVisible="False"
                             BackgroundColor="#0000AA"
                             Padding="30"
                             VerticalOptions="Fill">
            <Label Text="CRITICAL_BRAIN_ERROR"
                   TextColor="White" FontSize="28" FontAttributes="Bold"
                   Margin="0,60,0,20"/>
            <Label Text="Твой мозг выполнил недопустимую операцию и будет перезапущен."
                   TextColor="White" FontSize="16" Margin="0,0,0,10"/>
            <Label Text="STOP: 0x000000DUMB (0xBADBAD00, 0x00000000)"
                   TextColor="White" FontSize="12" FontFamily="Courier New"/>
            <ActivityIndicator IsRunning="True" Color="White" Margin="0,30"/>
            <Label x:Name="BsodHintLabel"
                   Text="" TextColor="#AAAAAA" FontSize="11"
                   HorizontalTextAlignment="Center" Margin="0,20,0,0"/>
        </VerticalStackLayout>

        <!-- краш 2 обновление -->
        <VerticalStackLayout x:Name="CrashUpdate"
                             IsVisible="False"
                             BackgroundColor="#1E1E2E"
                             Padding="40"
                             VerticalOptions="Center">
            <Label Text="⚙️" FontSize="64" HorizontalTextAlignment="Center"/>
            <Label Text="Устанавливается обновление 1 из 1..."
                   TextColor="White" FontSize="20" FontAttributes="Bold"
                   HorizontalTextAlignment="Center" Margin="0,20,0,10"/>
            <ProgressBar x:Name="UpdateProgress" Progress="0"
                         ProgressColor="#7C3AED" Margin="0,10"/>
            <Label x:Name="UpdatePercentLabel"
                   Text="0%" TextColor="#AAAAAA"
                   HorizontalTextAlignment="Center"/>
            <Label x:Name="UpdateHintLabel"
                   Text="" TextColor="#555577" FontSize="11"
                   HorizontalTextAlignment="Center" Margin="0,30,0,0"/>
        </VerticalStackLayout>

        <!-- краш 3 разбитый экран -->
        <Grid x:Name="CrashCrack" IsVisible="False">
            <BoxView BackgroundColor="#000000" Opacity="0.7"/>
            <Image Source="crack.png"
                   Aspect="AspectFill"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill"/>
        </Grid>

        <!-- краш 4 хакерская атака -->
        <VerticalStackLayout x:Name="CrashHack"
                             IsVisible="False"
                             BackgroundColor="Black"
                             Padding="20"
                             VerticalOptions="Fill">
            <Label Text="root@fsb:~#"
                   TextColor="#00FF41" FontSize="16" FontFamily="Courier New"
                   Margin="0,60,0,0"/>
            <Label x:Name="HackLabel"
                   Text="" TextColor="#00FF41"
                   FontSize="14" FontFamily="Courier New"/>
        </VerticalStackLayout>

        <!-- краш 5 батарейка -->
        <VerticalStackLayout x:Name="CrashBattery"
                             IsVisible="False"
                             BackgroundColor="Black"
                             VerticalOptions="Center">
            <Label x:Name="BatteryIcon"
                   Text="🪫" FontSize="80"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Батарея неисправна"
                   TextColor="#555555" FontSize="18"
                   HorizontalTextAlignment="Center" Margin="0,10"/>
        </VerticalStackLayout>

    </Grid>
</ContentView>