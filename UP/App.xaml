<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:QuizOrDie.Converters"
             x:Class="QuizOrDie.App">
    <Application.Resources>
        <ResourceDictionary>

            <!-- глобальные конверторы -->
            <converters:BoolToColorConverter   x:Key="BoolToColorConverter"/>
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
            <converters:InverseBoolConverter   x:Key="InverseBoolConverter"/>

            <!-- стиль кнопок ответов -->
            <Style x:Key="AnswerButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#1E1E2E"/>
                <Setter Property="TextColor" Value="White"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="HeightRequest" Value="56"/>
                <Setter Property="BorderColor" Value="#333355"/>
                <Setter Property="BorderWidth" Value="1"/>
                <Setter Property="HorizontalOptions" Value="Fill"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>